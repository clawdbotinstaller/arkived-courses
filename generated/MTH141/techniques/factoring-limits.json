          "correctAnswer": 0,
          "explanation": "0/0 form, polynomials - factor and cancel"
        },
        {
          "integral": "\\lim_{x \\to 3} \\frac{x^2-9}{x^2-5x+6}",
          "options": ["Direct substitution", "Factor both", "Rationalize", "No limit"],
          "correctAnswer": 1,
          "explanation": "0/0 form - factor numerator and denominator"
        },
        {
          "integral": "\\lim_{x \\to 4} \\frac{x+4}{x-4}",
          "options": ["Factor", "Direct substitution", "Does not exist", "Equals 0"],
          "correctAnswer": 2,
          "explanation": "Not 0/0 - numerator is 8, denominator is 0, so limit DNE (infinite)"
        }
      ]
    },
    "executionDrill": {
      "title": "Factoring Limits Execution",
      "problems": [
        {
          "problem": "Evaluate \\lim_{x \\to -1} \\frac{x^2-1}{x+1}",
          "answer": "-2",
          "hint": "x²-1 = (x-1)(x+1), cancel (x+1)",
          "difficulty": "Easy"
        },
        {
          "problem": "Evaluate \\lim_{x \\to 2} \\frac{x^2-3x+2}{x^2-4}",
          "answer": "\\frac{1}{4}",
          "hint": "Num: (x-1)(x-2), Den: (x-2)(x+2)",
          "difficulty": "Medium"
        },
        {
          "problem": "Evaluate \\lim_{h \\to 0} \\frac{(2+h)^2-4}{h}",
          "answer": "4",
          "hint": "Expand (2+h)² = 4 + 4h + h², simplify numerator",
          "difficulty": "Hard"
        }
      ]
    },
    "examStyleDrill": {
      "title": "Exam-Style Factoring Limits",
      "problems": [
        {
          "problem": "Evaluate lim(x→2) (x³-8)/(x²-4)",
          "context": "Difference of cubes and squares",
          "primaryTechnique": "factoring_limits",
          "secondaryTechniques": []
        },
        {
          "problem": "Find f'(2) using the limit definition for f(x) = x²",
          "context": "Factoring in derivative definition",
          "primaryTechnique": "factoring_limits",
          "secondaryTechniques": ["derivative_limit_def"]
        }
      ]
    }
  },
  "cheatSheet": {
    "oneLiner": "0/0 form → factor numerator and denominator → cancel common factors → substitute",
    "whenToUse": [
      "0/0 indeterminate form",
      "Rational functions (polynomials)",
      "Common factor visible or found by factoring"
    ],
    "formula": "\\lim_{x \\to a} \\frac{P(x)}{Q(x)} = \\lim_{x \\to a} \\frac{(x-a)P_1(x)}{(x-a)Q_1(x)} = \\lim_{x \\to a} \\frac{P_1(x)}{Q_1(x)} \\text{ (when } P(a)=Q(a)=0\\text{)}",
    "quickCheck": "Always try direct substitution first - if 0/0, then factor"
  },
  "patternConnections": [
    "limit_direct_substitution",
    "limit_rationalizing",
    "lhopital_0_0",
    "derivative_limit_def"
  ],
  "masteryCriteria": {
    "recognitionSpeed": "< 5 seconds to identify factoring approach",
    "executionSpeed": "< 4 minutes for standard problems",
    "accuracyTarget": "90% correct on drill sets",
    "selfCheckQuestions": [
      "Did I verify 0/0 form first?",
      "Did I factor completely?",
      "Did I cancel factors (not terms)?"
    ]
  }
}
