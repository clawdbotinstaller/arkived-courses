      ]
    }
  },
  "cheatSheet": {
    "oneLiner": "Differentiate both sides with respect to x, apply chain rule to y terms, solve for dy/dx",
    "whenToUse": [
      "y is not isolated",
      "Cannot easily solve for y",
      "Finding slope of implicitly defined curve"
    ],
    "formula": "\\frac{d}{dx}[y^n] = ny^{n-1}\\frac{dy}{dx}, \\quad \\frac{d}{dx}[xy] = y + x\\frac{dy}{dx}",
    "quickCheck": "Every y term should have a dy/dx factor after differentiation"
