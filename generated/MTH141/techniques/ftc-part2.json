  "cheatSheet": {
    "oneLiner": "∫_a^b f(x) dx = F(b) - F(a) where F is any antiderivative",
    "whenToUse": [
      "Definite integrals with constant bounds",
      "Computing accumulated change",
      "Finding areas under curves"
    ],
    "formula": "\\int_a^b f(x) \\, dx = F(b) - F(a) = [F(x)]_a^b",
