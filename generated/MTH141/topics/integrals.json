      "name": "Integration by Substitution",
      "recognition_signal": "Composite function with inner function derivative present",
      "canonical_forms": ["\\int f(g(x))g'(x) \\, dx = \\int f(u) \\, du"],
      "logic": "Let u = inner function, du = derivative dx, rewrite and integrate",
      "worked_example": {
        "title": "u-Substitution",
        "problem_latex": "\\int 2x \\cos(x^2) \\, dx",
        "solution_steps": [
          {"step": 1, "action": "Choose u", "latex": "u = x^2"},
          {"step": 2, "action": "Find du", "latex": "du = 2x \\, dx"},
          {"step": 3, "action": "Substitute", "latex": "\\int \\cos(u) \\, du"},
          {"step": 4, "action": "Integrate", "latex": "\\sin(u) + C"},
          {"step": 5, "action": "Back-substitute", "latex": "\\sin(x^2) + C"}
        ]
      }
    }
