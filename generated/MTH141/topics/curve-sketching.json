          {"step": 1, "action": "First derivative", "latex": "f'(x) = 3x^2"},
          {"step": 2, "action": "Second derivative", "latex": "f''(x) = 6x"},
          {"step": 3, "action": "Inflection point", "latex": "f'' = 0 \\text{ at } x = 0"},
          {"step": 4, "action": "Test", "reasoning": "x < 0: f'' < 0 (down); x > 0: f'' > 0 (up)"}
        ]
      }
    }
