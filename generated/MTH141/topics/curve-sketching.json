      "recognition_signal": "Concave up/down, inflection points",
      "canonical_forms": ["f''(x) > 0 \\Rightarrow \\text{concave up (cup)}, f''(x) < 0 \\Rightarrow \\text{concave down (frown)}"],
      "logic": "Sign of second derivative tells concavity",
      "worked_example": {
        "title": "Concavity Analysis",
        "problem_latex": "f(x) = x^3, \\text{ find concavity}",
