  "id": "spring_constant_energy",
  "name": "Spring Constant from Energy or Oscillation",
  "description": "Determine spring constant k from oscillation period, frequency, or energy considerations",
  "canonical_form_latex": "k = \\frac{4\\pi^2 m}{T^2} = m\\omega^2, \\quad U = \\frac{1}{2}kx^2",
  "identification_signal": "Finding spring constant from period measurements or energy stored",
  "frequency": "Medium",
  "estimated_time": "4-6 minutes",
  "strategy": {
    "step_1": "From oscillation: use ω = √(k/m) to get k = mω² = 4π²m/T²",
    "step_2": "From energy: if U and x known, k = 2U/x²",
    "step_3": "From force: k = F/x (Hooke's law)",
    "step_4": "Units: k in N/m = kg/s²"
  },
