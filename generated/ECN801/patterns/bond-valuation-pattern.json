  "frequency": "Common - appears in 60% of exams",
  "estimated_time": "8-12 minutes",
  "strategy": {
    "step_1": "Identify: Face F, Coupon rate c, Yield i, Maturity n, Periods per year",
    "step_2": "Adjust for semi-annual: divide annual rates by 2, double years",
    "step_3": "Calculate periodic coupon: C = F × (coupon rate per period)",
    "step_4": "Bond price = PV(coupons) + PV(face value)"
  },
